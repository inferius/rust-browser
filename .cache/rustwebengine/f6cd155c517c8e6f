                $(this).select2();
            }
        });

        if (window.innerHeight < 960) {
            $('select').on('select2:open', function() {
                $('.select2-search input').prop('focus', 0);
            });
        }

        $('.counter-up').counterUp({
            delay: 10,
            time: 2000,
            formatter: (f) => {
                const n = parseInt(f);
                if (isNaN(n)) return f;

                return n?.toLocaleString() ?? n;
            }
        });
    });
    </script>



