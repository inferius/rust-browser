  "html_source": "<!DOCTYPE html>\n<html><head><meta charset=\"utf-8\"><title>position_abs_pct</title>\n<style>\n* { box-sizing: border-box; margin: 0; padding: 0; }\nbody { font-family: Arial; padding: 10px; }\n.cb { position: relative; width: 500px; height: 300px; background: #eef; }\n.tl-pct { position: absolute; top: 25%; left: 25%; width: 60px; height: 30px; background: #c00; }\n.br-pct { position: absolute; bottom: 25%; right: 25%; width: 60px; height: 30px; background: #060; }\n.full-pct { position: absolute; top: 10%; left: 10%; right: 10%; bottom: 10%; background: #00c; }\n</style>\n</head><body>\n<div class=\"cb\">\n  <div id=\"a\" class=\"tl-pct\">top-left %</div>\n  <div id=\"b\" class=\"br-pct\">bottom-right %</div>\n  <div id=\"c\" class=\"full-pct\">full %</div>\n</div>\n</body></html>",
