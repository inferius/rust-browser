  "html_source": "<!DOCTYPE html>\n<html><head><meta charset=\"utf-8\"><title>position_abs</title>\n<style>\n* { box-sizing: border-box; margin: 0; padding: 0; }\nbody { font-family: Arial; padding: 20px; }\n.container { position: relative; width: 400px; height: 200px; background: #eef; margin-bottom: 10px; }\n.tl { position: absolute; top: 10px; left: 10px; width: 80px; height: 40px; background: #c00; }\n.br { position: absolute; bottom: 10px; right: 10px; width: 80px; height: 40px; background: #060; }\n.fixed-c { position: absolute; top: 50%; left: 50%; width: 60px; height: 30px; background: #00c; }\n</style>\n</head><body>\n<div class=\"container\">\n  <div id=\"a\" class=\"tl\">top-left</div>\n  <div id=\"b\" class=\"br\">bottom-right</div>\n  <div id=\"c\" class=\"fixed-c\">middle</div>\n</div>\n</body></html>",
