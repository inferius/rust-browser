  "html_source": "<!DOCTYPE html>\n<html><head><meta charset=\"utf-8\"><title>letter_spacing</title>\n<style>\n* { box-sizing: border-box; margin: 0; padding: 0; }\nbody { font-family: Arial; padding: 20px; font-size: 16px; }\n.tight { letter-spacing: -1px; }\n.normal { letter-spacing: normal; }\n.wide { letter-spacing: 4px; }\n.em-wide { letter-spacing: 0.2em; }\n.box { padding: 8px; margin-bottom: 6px; background: #eef; display: inline-block; }\n</style>\n</head><body>\n<div id=\"a\" class=\"box tight\">TIGHT TEXT</div>\n<div id=\"b\" class=\"box normal\">NORMAL TEXT</div>\n<div id=\"c\" class=\"box wide\">WIDE TEXT</div>\n<div id=\"d\" class=\"box em-wide\">EM WIDE</div>\n</body></html>",
