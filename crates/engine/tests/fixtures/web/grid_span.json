  "html_source": "<!DOCTYPE html>\n<html><head><meta charset=\"utf-8\"><title>grid_span</title>\n<style>\n* { box-sizing: border-box; margin: 0; padding: 0; }\nbody { font-family: Arial; font-size: 16px; }\n.grid {\n  display: grid;\n  grid-template-columns: repeat(4, 80px);\n  grid-template-rows: repeat(3, 50px);\n  gap: 5px;\n  width: 335px;\n}\n.cell { background: #bbb; }\n#big { grid-column: span 2; grid-row: span 2; background: #f88; }\n#wide { grid-column: 1 / -1; background: #88f; }\n</style>\n</head><body>\n<div class=\"grid\">\n  <div id=\"big\" class=\"cell\">big</div>\n  <div id=\"x1\" class=\"cell\">x1</div>\n  <div id=\"x2\" class=\"cell\">x2</div>\n  <div id=\"x3\" class=\"cell\">x3</div>\n  <div id=\"x4\" class=\"cell\">x4</div>\n  <div id=\"wide\" class=\"cell\">wide</div>\n</div>\n</body></html>",
