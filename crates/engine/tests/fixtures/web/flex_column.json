  "html_source": "<!DOCTYPE html>\n<html><head><meta charset=\"utf-8\"><title>flex_column</title>\n<style>\n* { box-sizing: border-box; margin: 0; padding: 0; }\nbody { font-family: Arial; padding: 20px; }\n.col-wrap {\n  display: flex;\n  flex-direction: column;\n  gap: 30px;\n  width: 400px;\n}\n.item {\n  background: #eef;\n  padding: 10px;\n}\n.h100 { height: 100px; }\n.h150 { height: 150px; }\n.h-auto-tall { padding: 20px; }\n.tall-inner { height: 80px; background: #fee; }\n</style>\n</head><body>\n<div class=\"col-wrap\">\n  <div id=\"a\" class=\"item h100\">Item 1: 100px</div>\n  <div id=\"b\" class=\"item h150\">Item 2: 150px</div>\n  <div id=\"c\" class=\"item h-auto-tall\">\n    <div class=\"tall-inner\">Item 3: auto-height with nested 80px</div>\n  </div>\n</div>\n</body></html>",
